# ─── Database ───
DATABASE_URL=postgresql://economyzee:economyzee@localhost:5432/economyzee

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth ───
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION=7d

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=EconomyZeeBot
WEBHOOK_SECRET=random-webhook-secret-string
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/integrations/telegram/webhook

# ─── Google Gemini AI ───
GEMINI_API_KEY=your-google-gemini-api-key

# ─── Supabase Auth ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── App ───
APP_URL=http://localhost:3000
APP_PORT=3000
FRONTEND_URL=https://economyzee.com
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,https://economyzee.com,https://www.economyzee.com,https://economyzee-smart-finance-hub-main.vercel.app
NODE_ENV=development

# Email / Resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=EconomyZee <noreply@economyzee.com>

# ─── Timezone ───
TZ=America/Sao_Paulo
