{
  "name": "economyzee-backend",
  "version": "1.0.0",
  "private": true,
  "description": "EconomyZee Backend — NestJS + Prisma + Telegram + Gemini AI",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "workspace:ensure-owners": "tsx prisma/scripts/ensure-workspace-owners.ts",
    "db:setup": "prisma migrate dev && tsx prisma/seed.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "dev:init": "npm run docker:up && npm run db:generate && npm run db:migrate",
    "dev": "npm run dev:init && npm run start:dev",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:unit": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.105.1",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.15.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.25.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.30.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsqr": "^1.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.31.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
